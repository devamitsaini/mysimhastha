{
  "installCommand": "npm install --legacy-peer-deps",

  "redirects": [
    {
      "source": "/guide/bhasma-aarti",
      "destination": "/guide/bhasma-arti",
      "permanent": true
    },
    {
      "source": "/hi/guide/bhasma-aarti",
      "destination": "/hi/guide/bhasma-arti",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],

  "headers": [
    {
      "source": "/(.*).(js|css|png|jpg|jpeg|webp|svg|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}