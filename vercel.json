{
  "installCommand": "npm install --legacy-peer-deps",

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],

  "headers": [
    {
      "source": "/(.*).(js|css|png|jpg|jpeg|webp|svg|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}