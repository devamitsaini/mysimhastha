{
  "installCommand": "npm install --legacy-peer-deps",

  "redirects": [
    {
      "source": "/guide/bhasma-aarti",
      "destination": "/guide/bhasma-arti",
      "permanent": true
    },
    {
      "source": "/hi/guide/bhasma-aarti",
      "destination": "/hi/guide/bhasma-arti",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "mysimhastha.com"
        }
      ],
      "destination": "https://www.mysimhastha.com/$1",
      "permanent": true
    },
    {
  "redirects": [
    {
      "source": "/hi/guide/ujjain-kaise-pahunche",
      "destination": "/hi/guide/how-to-reach-ujjain",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
  ],
  

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}